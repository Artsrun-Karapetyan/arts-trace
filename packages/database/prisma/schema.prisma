generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(cuid())
  name      String
  apiKey    String   @unique
  createdAt DateTime @default(now())

  issues    Issue[]
  events    Event[]
  sourceMaps SourceMap[]
}

model Issue {
  id          String   @id @default(cuid())

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])

  fingerprint String
  message     String
  count       Int      @default(1)
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())

  events      Event[]

  @@unique([projectId, fingerprint])
  @@index([projectId, lastSeen])
}

model Event {
  id        String   @id @default(cuid())

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  issueId   String?
  issue     Issue?   @relation(fields: [issueId], references: [id])

  message   String
  stack     String?
  fileName  String?
  line      Int?
  column    Int?
  url       String
  userAgent String?
  userId    String?

  createdAt DateTime @default(now())

  breadcrumbs Breadcrumb[]
  networkRequests NetworkRequest[]
  replays ReplayChunk[]

  @@index([projectId, createdAt])
}

model Breadcrumb {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  type      String
  message   String
  data      Json?
  createdAt DateTime

  @@index([eventId, createdAt])
}

model NetworkRequest {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  method    String
  url       String
  status    Int?
  requestHeaders Json?
  requestBody String?
  responseHeaders Json?
  responseBody String?
  error String?
  duration  Int?
  createdAt DateTime

  @@index([eventId, createdAt])
}

model ReplayChunk {
  id        String   @id @default(cuid())
  eventId   String   @unique
  event     Event    @relation(fields: [eventId], references: [id])
  events    Json
  createdAt DateTime @default(now())
}

model SourceMap {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release   String   // release version
  fileName  String   // e.g. "assets/index-c87fa1a2.js"
  content   String   // source map content
  createdAt DateTime @default(now())

  @@unique([projectId, release, fileName])
  @@index([projectId, release])
}

